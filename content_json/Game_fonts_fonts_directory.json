  "sections": [
    {
      "heading": {
        "level": 2,
        "text": "Game fonts",
        "id": "Game_fonts"
      },
      "content": [
        {
          "type": "paragraph",
          "text": "You must upload in a `fonts` directory all fonts that you will use in your game interface."
        },
        {
          "type": "paragraph",
          "text": "The you can use them by setting a font-family with the filename (note the dashes will be replaced by spaces), without needing to declare a `@font-face`."
        }
      ]
    },
    {
      "heading": {
        "level": 2,
        "text": "Example",
        "id": "Example"
      },
      "content": [
        {
          "type": "paragraph",
          "text": "With a `custom-font.woff2` in the `fonts` directory:"
        },
        {
          "type": "code",
          "language": null,
          "text": "  .element-with-custom-font {\n    font-family: 'custom font';\n  }"
        },
        {
          "type": "paragraph",
          "text": "With a `custom-font-bold.woff2` in the `fonts` directory:"
        },
        {
          "type": "code",
          "language": null,
          "text": "  .element-with-custom-font-bold-solution1 {\n    font-family: 'custom font';\n    font-weight: bold;\n  }\n  .element-with-custom-font-bold-solution2 {\n    font-family: 'custom font bold';\n  }"
        }
      ]
    },
    {
      "heading": {
        "level": 2,
        "text": "Debugging",
        "id": "Debugging"
      },
      "content": [
        {
          "type": "paragraph",
          "text": "In the DevTool console, write `document.getElementById('bga-auto-declared-font-faces')` to list the fonts that are preloaded by the framework."
        }
      ]
    }
  ],
