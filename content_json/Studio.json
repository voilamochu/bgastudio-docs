    {
      "type": "paragraph",
      "text": "Versions currently used by BGA framework:"
    },
    {
      "type": "list",
      "ordered": false,
      "items": [
        {
          "text": "Dojo Toolkit 1.15 - deprecated, avoid at all cost",
          "nested": null
        },
        {
          "text": "PHP: 8.4",
          "nested": null
        },
        {
          "text": "SQL: MySQL 5.7 (prod) - on studio 8.0",
          "nested": null
        },
        {
          "text": "JS/CSS/HTML: limited by what minimization tools support: JS minimization",
          "nested": null
        },
        {
          "text": "Font Awesome: 4.7 https://fontawesome.com/v4.7/icons/ (available as `<i class=\"fa fa-clock\" />` )",
          "nested": null
        },
        {
          "text": "Font Awesome: 6.4.0 https://fontawesome.com/v6/search?o=r&m=free (available as `<i class=\"fa6 fa6-clock\" />` )",
          "nested": null
        }
      ]
    },
